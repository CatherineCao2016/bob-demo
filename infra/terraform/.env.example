# =============================================================================
# .env.example — Environment variables required before running terraform apply
# =============================================================================
#
# Copy this file, fill in the real values, and source it in your shell:
#
#   cp .env.example .env
#   # edit .env with real values
#   source .env
#   terraform init
#   terraform apply
#
# NEVER commit the populated .env file to source control.
# Add ".env" to your .gitignore.
#
# All variables follow the TF_VAR_<name> convention so Terraform picks them
# up automatically without needing a -var flag on the command line.
# =============================================================================

# -----------------------------------------------------------------------------
# GitHub provider credentials
# -----------------------------------------------------------------------------

# Personal Access Token with "repo" scope (classic) or a fine-grained token
# with "Secrets: Read and write" permission on the target repository.
export TF_VAR_github_token="ghp_REPLACE_WITH_YOUR_GITHUB_PAT"

# GitHub organisation or personal account that owns the repository.
# Example: "my-org" or "my-github-username"
export TF_VAR_github_owner="REPLACE_WITH_GITHUB_OWNER"

# Name of the repository where the Actions secrets will be created.
# Example: "payment-app"
export TF_VAR_github_repository="REPLACE_WITH_REPO_NAME"

# -----------------------------------------------------------------------------
# OpenShift cluster connectivity (also used by the kubernetes/openshift providers
# defined in provider.tf — these mirror TF_VAR_cluster_url / cluster_token)
# -----------------------------------------------------------------------------

# OpenShift cluster API URL.
# Example: https://api.cluster.example.com:6443
export TF_VAR_cluster_url="https://REPLACE_WITH_OPENSHIFT_API_URL:6443"

# Service account bearer token with sufficient privileges.
# Obtain with: oc whoami -t   (after logging in as the service account)
export TF_VAR_cluster_token="REPLACE_WITH_OPENSHIFT_SA_TOKEN"

# -----------------------------------------------------------------------------
# GitHub Actions secret values — OpenShift
# -----------------------------------------------------------------------------

# OpenShift cluster API URL stored as the OPENSHIFT_SERVER Actions secret.
# Typically the same value as TF_VAR_cluster_url above.
export TF_VAR_openshift_server="https://REPLACE_WITH_OPENSHIFT_API_URL:6443"

# Service account token stored as the OPENSHIFT_TOKEN Actions secret.
# Typically the same value as TF_VAR_cluster_token above.
export TF_VAR_openshift_token="REPLACE_WITH_OPENSHIFT_SA_TOKEN"

# Internal image registry route stored as the OPENSHIFT_REGISTRY Actions secret.
# Retrieve the value with:
#   oc get route default-route \
#     -n openshift-image-registry \
#     --template='{{ .spec.host }}'
# Example: default-route-openshift-image-registry.apps.cluster.example.com
export TF_VAR_openshift_registry="REPLACE_WITH_REGISTRY_ROUTE_HOST"

# -----------------------------------------------------------------------------
# Namespace names (optional — defaults are already set in variables.tf)
# -----------------------------------------------------------------------------

# Uncomment and override only if you need values different from the defaults:
#   staging_namespace = "bob-demo-staging"
#   prod_namespace    = "bob-demo-prod"
#
# export TF_VAR_staging_namespace="bob-demo-staging"
# export TF_VAR_prod_namespace="bob-demo-prod"
# -----------------------------------------------------------------------------
# Ansible — PostgreSQL database passwords
# -----------------------------------------------------------------------------
# Used by the Ansible playbook (playbook.yml) to create the postgres-credentials
# Secret in each namespace. Source this file before running ansible-playbook:
#
#   source .env
#   cd ../../ansible
#   ansible-playbook -i inventory/hosts.yml playbook.yml

# Password for the PostgreSQL instance in bob-demo-staging
export STAGING_DB_PASSWORD="REPLACE_WITH_STAGING_DB_PASSWORD"

# Password for the PostgreSQL instance in bob-demo-prod
export PROD_DB_PASSWORD="REPLACE_WITH_PROD_DB_PASSWORD"